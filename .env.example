# VAPT Navigator Environment
# Copy to .env and adjust

# Database (Docker PostgreSQL)
DATABASE_URL=postgresql+asyncpg://navigator:navigator_secure_password@31.97.236.44:5432/navigator

# Redis (shared on DB server when using multiple app servers)
REDIS_URL=redis://31.97.236.44:6379/1

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Storage: local (filesystem) or r2 (Cloudflare R2 / S3-compatible)
#STORAGE_BACKEND=local
#STORAGE_BACKEND=r2

# R2 (when STORAGE_BACKEND=r2). Do not commit real credentials.
#R2_ENDPOINT_URL=https://9ab3ee94bcb16f9d16f16f1ca4511c6c.r2.cloudflarestorage.com
#R2_BUCKET=maphra-production-dedsec
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_REGION=auto

# Paths (default for /opt/navigator; used when STORAGE_BACKEND=local)
# PAYLOADS_PATH=/opt/navigator/data/PayloadsAllTheThings
# SECLISTS_PATH=/opt/navigator/data/SecLists
