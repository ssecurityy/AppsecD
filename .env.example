# VAPT Navigator Environment
# Copy to .env and adjust

# Database (Docker PostgreSQL)
DATABASE_URL=postgresql+asyncpg://navigator:navigator_secure_password@127.0.0.1:5433/navigator

# Redis
REDIS_URL=redis://127.0.0.1:6379/1

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Paths (default for /opt/navigator)
# PAYLOADS_PATH=/opt/navigator/data/PayloadsAllTheThings
# SECLISTS_PATH=/opt/navigator/data/SecLists
